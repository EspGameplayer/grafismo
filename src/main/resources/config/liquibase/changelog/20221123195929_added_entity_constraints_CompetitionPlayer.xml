                                 baseTableName="rel_competition_player__preferred_position"
                                 constraintName="fk_rel_competition_player__pref__competition_player_f0_id"
                                 referencedColumnNames="id"
                                 referencedTableName="competition_player"/>

        <addForeignKeyConstraint baseColumnNames="preferred_position_id"
                                 baseTableName="rel_competition_player__preferred_position"
                                 constraintName="fk_rel_competition_player__pref__preferred_position_10_id"
                                 referencedColumnNames="id"
                                 referencedTableName="position"/>
    </changeSet>
</databaseChangeLog>
