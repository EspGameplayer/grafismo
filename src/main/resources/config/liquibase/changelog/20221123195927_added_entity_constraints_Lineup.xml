<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">
    <!--
        Added the constraints for entity Lineup.
    -->
    <changeSet id="20221123195927-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="callup_id"
                                 baseTableName="lineup"
                                 constraintName="fk_lineup__callup_id"
                                 referencedColumnNames="id"
                                 referencedTableName="callup"/>

        <addForeignKeyConstraint baseColumnNames="formation_id"
                                 baseTableName="lineup"
                                 constraintName="fk_lineup__formation_id"
                                 referencedColumnNames="id"
                                 referencedTableName="formation"/>

        <addForeignKeyConstraint baseColumnNames="lineup_id"
                                 baseTableName="rel_lineup__player"
                                 constraintName="fk_rel_lineup__player__lineup_id"
                                 referencedColumnNames="id"
                                 referencedTableName="lineup"/>

        <addForeignKeyConstraint baseColumnNames="player_id"
                                 baseTableName="rel_lineup__player"
                                 constraintName="fk_rel_lineup__player__player_id"
                                 referencedColumnNames="id"
                                 referencedTableName="match_player"/>
    </changeSet>
</databaseChangeLog>
