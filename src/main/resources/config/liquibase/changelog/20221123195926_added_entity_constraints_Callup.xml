                                 constraintName="fk_callup__dt_id"
                                 referencedColumnNames="id"
                                 referencedTableName="team_staff_member"/>

        <addForeignKeyConstraint baseColumnNames="dt2_id"
                                 baseTableName="callup"
                                 constraintName="fk_callup__dt2_id"
