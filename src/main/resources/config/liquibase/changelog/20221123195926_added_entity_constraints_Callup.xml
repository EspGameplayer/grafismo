        <addForeignKeyConstraint baseColumnNames="team_delegate_id"
                                 baseTableName="callup"
                                 constraintName="fk_callup__team_delegate_id"
                                 referencedColumnNames="id"
                                 referencedTableName="team_staff_member"/>

        <addForeignKeyConstraint baseColumnNames="callup_id"
                                 baseTableName="rel_callup__player"
                                 constraintName="fk_rel_callup__player__callup_id"
                                 referencedColumnNames="id"
                                 referencedTableName="callup"/>

        <addForeignKeyConstraint baseColumnNames="player_id"
                                 baseTableName="rel_callup__player"
                                 constraintName="fk_rel_callup__player__player_id"
                                 referencedColumnNames="id"
