<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">
    <!--
        Added the constraints for entity Action.
    -->
    <changeSet id="20221123195931-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="match_stats_id"
                                 baseTableName="action"
                                 constraintName="fk_action__match_stats_id"
                                 referencedColumnNames="id"
                                 referencedTableName="match_stats"/>

        <addForeignKeyConstraint baseColumnNames="action_id"
                                 baseTableName="rel_action__player"
                                 constraintName="fk_rel_action__player__action_id"
                                 referencedColumnNames="id"
                                 referencedTableName="action"/>

        <addForeignKeyConstraint baseColumnNames="player_id"
                                 baseTableName="rel_action__player"
                                 constraintName="fk_rel_action__player__player_id"
                                 referencedColumnNames="id"
                                 referencedTableName="player"/>
    </changeSet>
</databaseChangeLog>
