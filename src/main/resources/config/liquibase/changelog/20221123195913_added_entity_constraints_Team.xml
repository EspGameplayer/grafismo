<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">
    <!--
        Added the constraints for entity Team.
    -->
    <changeSet id="20221123195913-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="preferred_formation_id"
                                 baseTableName="team"
                                 constraintName="fk_team__preferred_formation_id"
                                 referencedColumnNames="id"
                                 referencedTableName="formation"/>

        <addForeignKeyConstraint baseColumnNames="team_id"
                                 baseTableName="rel_team__stadium"
                                 constraintName="fk_rel_team__stadium__team_id"
                                 referencedColumnNames="id"
                                 referencedTableName="team"/>

        <addForeignKeyConstraint baseColumnNames="stadium_id"
                                 baseTableName="rel_team__stadium"
                                 constraintName="fk_rel_team__stadium__stadium_id"
                                 referencedColumnNames="id"
                                 referencedTableName="stadium"/>
    </changeSet>
</databaseChangeLog>
